import socket
import pyautogui
import configparser
import os
import time

# 配置檔名稱
CONFIG_FILE = 'config.ini'

def load_config():
    config = configparser.ConfigParser()
    
    # 如果配置檔不存在，建立一個預設的
    if not os.path.exists(CONFIG_FILE):
        config['SERVER'] = {
            'ip': '192.168.1.100',
            'port': '65432'
        }
        config['SETTING'] = {
            'target_window_title': 'Notepad', # 填入你測試軟體的標題
            'auto_enter': 'True'
        }
        with open(CONFIG_FILE, 'w') as f:
            config.write(f)
        print(f"已產生預設配置檔 {CONFIG_FILE}，請修改後重啟程式。")
    
    config.read(CONFIG_FILE)
    return config

def start_client():
    cfg = load_config()
    server_ip = cfg['SERVER']['ip']
    port = int(cfg['SERVER']['port'])
    target_title = cfg['SETTING']['target_window_title']
    
    try:
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            print(f"正在連線至伺服器 {server_ip}...")
            s.connect((server_ip, port))
            print("連線成功！監聽中...")
            
            while True:
                data = s.recv(1024)
                if not data:
                    break
                
                barcode = data.decode('utf-8')
                print(f"接收到條碼: {barcode}")
                
                # --- 視窗自動聚焦邏輯 ---
                # 嘗試尋找標題含有 target_title 的視窗
                windows = pyautogui.getWindowsWithTitle(target_title)
                if windows:
                    win = windows[0]
                    if not win.isActive:
                        win.activate() # 激發視窗
                        time.sleep(0.1) # 等待視窗反應
                
                # 模擬輸入
                pyautogui.write(barcode)
                if cfg['SETTING'].getboolean('auto_enter'):
                    pyautogui.press('enter')
                
    except Exception as e:
        print(f"發生錯誤: {e}")
        input("按任意鍵結束...")

if __name__ == "__main__":
    start_client()
