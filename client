import socket
import pyautogui
import configparser
import os
import time

# 配置檔名稱
CONFIG_FILE = 'config.ini'

def load_config():
    config = configparser.ConfigParser()
    if not os.path.exists(CONFIG_FILE):
        config['SERVER'] = {
            'ip': '192.168.1.100',
            'port': '65432'
        }
        config['SETTING'] = {
            'auto_enter': 'True',
            'delay_seconds': '0.5'
        }
        with open(CONFIG_FILE, 'w') as f:
            config.write(f)
        print(f"已產生預設配置檔 {CONFIG_FILE}。")
    
    config.read(CONFIG_FILE)
    return config

def start_client():
    cfg = load_config()
    server_ip = cfg['SERVER']['ip']
    port = int(cfg['SERVER']['port'])
    delay_sec = cfg['SETTING'].getfloat('delay_seconds')
    
    try:
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            print(f"正在連線至伺服器 {server_ip}...")
            # 增加連線逾時設定，防止程式永久卡死
            s.settimeout(10)
            s.connect((server_ip, port))
            s.settimeout(None) # 連線成功後恢復為阻塞模式
            print("連線成功！數據監聽中...")
            
            while True:
                data = s.recv(1024)
                if not data:
                    break
                
                barcode = data.decode('utf-8')
                print(f"接收到數據: {barcode}")
                
                # 執行延時：確保數據接收與模擬輸入之間有緩衝
                if delay_sec > 0:
                    time.sleep(delay_sec)
                
                # 直接在當前游標處輸入
                pyautogui.write(barcode)
                if cfg['SETTING'].getboolean('auto_enter'):
                    pyautogui.press('enter')
                
    except Exception as e:
        print(f"連線中斷或錯誤: {e}")
        input("按任意鍵重新啟動或結束...")

if __name__ == "__main__":
    start_client()
