import socket
import os
import configparser
from pynput import keyboard

# 配置檔名稱
CONFIG_FILE = 'server_config.ini'

def load_config():
    config = configparser.ConfigParser()
    if not os.path.exists(CONFIG_FILE):
        config['NETWORK'] = {
            'host': '0.0.0.0',
            'port': '65432'
        }
        config['FILTER'] = {
            'target_length': '15',      
            'target_prefix': 'DCZ300'   
        }
        config['LOGIC'] = {
            'scan_cycle_count': '3'     # 每個 MES 作業循環的總掃描次數
        }
        with open(CONFIG_FILE, 'w') as f:
            config.write(f)
        print(f"已產生預設配置檔 {CONFIG_FILE}。")
    
    config.read(CONFIG_FILE)
    return config

# 全域變數狀態管理
buffer = []
cycle_barcodes = []  # 用於暫存同一循環內的 n 個條碼

def start_server():
    cfg = load_config()
    HOST = cfg['NETWORK']['host']
    PORT = int(cfg['NETWORK']['port'])
    TARGET_LENGTH = int(cfg['FILTER']['target_length'])
    TARGET_PREFIX = cfg['FILTER']['target_prefix']
    SCAN_CYCLE_COUNT = int(cfg['LOGIC']['scan_cycle_count'])

    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.bind((HOST, PORT))
        s.listen()
        print(f"背景伺服器已啟動，等待電腦 B 連線... (Port: {PORT})")
        print(f"配置: 每 {SCAN_CYCLE_COUNT} 掃描為一循環，目標條件 [長度={TARGET_LENGTH}, 前綴='{TARGET_PREFIX}']")
        
        conn, addr = s.accept()
        with conn:
            print(f"已與電腦 B 連線: {addr}")

            def on_press(key):
                global buffer, cycle_barcodes
                try:
                    if hasattr(key, 'char') and key.char is not None:
                        buffer.append(key.char)
                    
                    elif key == keyboard.Key.enter:
                        if buffer:
                            barcode = "".join(buffer)
                            cycle_barcodes.append(barcode)
                            current_count = len(cycle_barcodes)
                            
                            print(f"[循環進度 {current_count}/{SCAN_CYCLE_COUNT}] 已記錄: {barcode}")
                            buffer = [] 
                            
                            # --- 循環計數達標，執行過濾與轉發 ---
                            if current_count >= SCAN_CYCLE_COUNT:
                                print("--- 循環完成，開始分析數據 ---")
                                target_to_send = None
                                
                                # 在該次循環的 n 個條碼中尋找符合條件者
                                for b in cycle_barcodes:
                                    is_valid = True
                                    if TARGET_LENGTH > 0 and len(b) != TARGET_LENGTH:
                                        is_valid = False
                                    if TARGET_PREFIX and not b.startswith(TARGET_PREFIX):
                                        is_valid = False
                                        
                                    if is_valid:
                                        target_to_send = b
                                        break # 找到首個符合目標即停止
                                
                                # 執行轉發
                                if target_to_send:
                                    conn.sendall(target_to_send.encode('utf-8'))
                                    print(f"==> 成功轉發目標條碼: {target_to_send}\n")
                                else:
                                    print("==> 警告: 此循環內查無符合規則的條碼，未轉發。\n")
                                
                                # 清空循環陣列，準備迎接下一個 MES 流程
                                cycle_barcodes = []

                    elif key == keyboard.Key.backspace:
                        if buffer:
                            buffer.pop()

                except Exception as e:
                    print(f"發送錯誤: {e}")

            with keyboard.Listener(on_press=on_press) as listener:
                listener.join()

if __name__ == "__main__":
    start_server()
